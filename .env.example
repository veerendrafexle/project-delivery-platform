# AI Delivery Platform environment configuration

# Local Ollama-compatible LLM endpoint
LOCAL_LLM_URL=http://localhost:11434/api/generate
MODEL=mistral

# OpenRouter remote API configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://api.openrouter.ai/v1/chat/completions

# Salesforce integration placeholders
SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret_here
SALESFORCE_USERNAME=your_salesforce_username_here
SALESFORCE_PASSWORD=your_salesforce_password_here

# Jira integration placeholders
JIRA_EMAIL=your_jira_email_here
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_DOMAIN=your_jira_domain_here
